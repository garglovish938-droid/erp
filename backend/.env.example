# =============================================================
# Allure Living ERP — Backend Environment Variables
# Copy these keys into Railway → Backend Service → Variables tab
# DO NOT commit actual values to GitLab.
# =============================================================

# ✅ Auto-set by Railway when you add the PostgreSQL plugin:
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# 🔑 Generate a strong secret (64+ characters):
SECRET_KEY=a9f3e8c2b4d1e6f7a0b3c5d8e2f4a7b9c1d3e5f8a2b4c6d9e1f3a5b7c0d2e4

# 📂 Persistent storage directories (use Railway volumes or cloud storage in production):
BACKUP_DIR=/app/backups
UPLOAD_DIR=/app/uploads
