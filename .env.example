# ============================================================
# ALLURE LIVING ERP - ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ============================================================

# ─────────────────────────────────────────────────────────────
# BACKEND (FastAPI)
# ─────────────────────────────────────────────────────────────

# JWT Secret Key — MUST be a long random string in production
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=your_super_secret_jwt_key_change_this_in_production

# Database URL — defaults to SQLite for local dev
# For PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./erp.db

# Token expiry in minutes (default: 600 = 10 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=600

# File storage directories (optional — defaults used if not set)
BACKUP_DIR=./backups
UPLOAD_DIR=./uploads

# Environment flag (production | development)
ENVIRONMENT=development

# ─────────────────────────────────────────────────────────────
# FRONTEND (Next.js)
# ─────────────────────────────────────────────────────────────

# Backend API URL — update for production deployment
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:8000
BACKEND_API_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────
# CLOUDFLARE TUNNEL (optional, for remote access)
# ─────────────────────────────────────────────────────────────

# Your Cloudflare Tunnel token (from cloudflared tunnel)
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# ─────────────────────────────────────────────────────────────
# RAILWAY / PRODUCTION DEPLOYMENT
# ─────────────────────────────────────────────────────────────

# Railway injects DATABASE_URL automatically via the PostgreSQL plugin
# SECRET_KEY must be set manually in Railway environment variables

# ─────────────────────────────────────────────────────────────
# NOTES
# ─────────────────────────────────────────────────────────────
# 1. In production, SECRET_KEY MUST be set — the app will refuse to start
#    if running in production mode without SECRET_KEY
# 2. If using PostgreSQL, ensure all SQLAlchemy models are compatible
# 3. Run `alembic upgrade head` after first deployment for migrations
